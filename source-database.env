# Connection to "source" OMOP database with clinical data

# Use EITHER this block of variables OR the _DRIVER and
# _CONNECTION_STRING variables below.
SOURCE_DB_HOST=host.containers.internal
SOURCE_DB_PORT=5432
SOURCE_DB_USER=postgres
SOURCE_DB_DATABASE=ohdsi
SOURCE_DB_SCHEMA=cds_cdm

# Specify the driver for non-postgres databases
#SOURCE_DB_DRIVER=
# JDBC connection string. If the _DRIVER variable is set, this
# variable must be set as well.
#SOURCE_DB_CONNECTION_STRING=
