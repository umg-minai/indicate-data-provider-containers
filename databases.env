# Connection to "source" OMOP database with clinical data
SOURCE_DB_HOST=host.containers.internal
SOURCE_DB_PORT=5432
SOURCE_DB_USER=postgres
SOURCE_DB_DATABASE=ohdsi
SOURCE_DB_SCHEMA=cds_cdm
# Specify the driver for non-postgres databases
#SOURCE_DB_DRIVER=
# EITHER the above OR use a connection URI
#SOURCE_DB_CONNECTION_STRING=

# Connection to "target" OMOP database with indicator results
# Since this references the more or less internal database in the "database"
# container, there should rarely be a need to change this.
TARGET_DB_HOST=database
TARGET_DB_PORT=5432
TARGET_DB_USER=postgres
TARGET_DB_DATABASE=ohdsi
TARGET_DB_SCHEMA=cds_cdm
